generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  createdAt     DateTime  @default(now())
  monitors      Monitor[]
  statusPages   StatusPage[]
  alertContacts AlertContact[]
}

model Monitor {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  url         String
  type        String      // HTTP, Ping, Port
  interval          Int         // Interval in minutes
  timeout           Int         @default(30) // Timeout in seconds
  status            String      @default("up") // up, down, paused
  isPersonalAlert   Boolean     @default(false)
  personalAlertEmail String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  checks            Check[]
  incidents         Incident[]
  statusPages       StatusPage[] @relation("MonitorToStatusPage")
}

model Check {
  id           String   @id @default(cuid())
  monitorId    String
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status       String   // up, down
  responseTime Int      // ms
  createdAt    DateTime @default(now())
}

model Incident {
  id          String    @id @default(cuid())
  monitorId   String
  monitor     Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status      String    // ongoing, resolved
  errorType   String?   
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

model StatusPage {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  domain      String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  monitors    Monitor[] @relation("MonitorToStatusPage")
}

model AlertContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // Email, SMS, Webhook
  value     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}